# ビルド成果物
/build/bin/
/frontend/dist/

# 依存
/frontend/node_modules/
node_modules/

# Wails 自動生成バインディング（ビルド時に再生成）
/frontend/wailsjs/

# 実行ファイル
*.exe

# ブラウザ版（GitHub Pages）のビルド時生成物（worker.js と .nojekyll はソースとして追跡）
/frontend/public/main.wasm
/frontend/public/wasm_exec.js
/frontend/public/lessons.json
/web/wasm/main.wasm

# 署名資材（絶対にコミットしない）
/certs/

tmp/
